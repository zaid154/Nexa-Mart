# ============================================================
# Demo / Seed login accounts (created by `npm run seed`)
#   Admin    -> admin@shop.com / Admin@123
#   Customer -> user@shop.com  / User@123
# ============================================================

# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# MongoDB Atlas — paste your connection string here
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/ecommerce

# JWT
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_this_to_another_long_random_secret
JWT_REFRESH_EXPIRES_IN=7d

# SMTP (real email — Gmail app password, SendGrid, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=NexaMart <your-email@gmail.com>

# OTP
OTP_EXPIRES_MIN=10
OTP_LENGTH=6

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# Cookies (set true in production with HTTPS)
COOKIE_SECURE=false

# Cloudinary (optional — new uploads use Cloudinary when set; legacy Mongo buffers still work)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Razorpay test keys — https://dashboard.razorpay.com
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
